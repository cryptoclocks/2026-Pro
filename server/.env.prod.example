# Production env for the Hub API container (docker-compose.prod.yml).
# On the OCI VM:  cp .env.prod.example .env.prod  then fill the real secrets.
# NEVER commit .env.prod — it is gitignored. Only this .example is tracked.

# --- database: Supabase Postgres -------------------------------------------
# Copy BOTH strings from Supabase Dashboard -> Settings -> Database.
#   DATABASE_URL  = "Connection pooling" (Transaction mode), port 6543
#   DIRECT_URL    = "Direct connection",  port 5432  (used only by migrations)
DATABASE_URL=postgresql://postgres.uadjxvagcnaebksaztpn:[PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.uadjxvagcnaebksaztpn:[PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres

# --- auth -------------------------------------------------------------------
JWT_SECRET=replace-with-a-long-random-string
SUPABASE_URL=https://uadjxvagcnaebksaztpn.supabase.co
# Same value as the web apps' NEXT_PUBLIC_/VITE_ SUPABASE_ANON_KEY (public key).
SUPABASE_ANON_KEY=your-supabase-anon-key
ADMIN_EMAILS=mycryptoclock@gmail.com
CCP_STAGED_ROLLOUT_OWNER_EMAIL=mycryptoclock@gmail.com

# --- mqtt broker (runs on the same VM) -------------------------------------
# The production compose joins the existing Node-RED broker network.
MQTT_URL=mqtt://jarvis-nodered:1883
MQTT_API_USERNAME=api-bridge
MQTT_API_PASSWORD=replace-me

# --- stripe (only needed if store/checkout is used) ------------------------
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- public URLs / CORS -----------------------------------------------------
# Comma-separated list of allowed web origins (admin + user web).
WEB_ORIGIN=https://admin.cashlessthailand.com,https://ccp-user.cashlessthailand.com
PUBLIC_API_URL=https://api.cashlessthailand.com
PUBLIC_WEB_URL=https://admin.cashlessthailand.com
PORT=4000
