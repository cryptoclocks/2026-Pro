# Public browser configuration. Values prefixed NEXT_PUBLIC_ are visible to the
# browser by design. Never put Supabase service_role keys or broker master
# passwords here.
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-publishable-or-anon-key
NEXT_PUBLIC_MQTT_WS_URL=wss://mqtt-ccp.cashlessthailand.com/mqtt
