// CryptoClock Pro Hub — database schema
// Postgres + Prisma. See plan §8 for the model map.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime connection. In production this is the Supabase pooler (port 6543).
  url       = env("DATABASE_URL")
  // Migrations need a direct session (not pgbouncer). Locally set this equal to
  // DATABASE_URL; in production point it at the Supabase direct port (5432).
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  ADVERTISER
  USER
}

enum ClaimStatus {
  PENDING
  CLAIMED
  EXPIRED
}

enum PayloadType {
  LAYOUT
  LAYOUT_WASM
}

enum PayloadStatus {
  DRAFT
  PUBLISHED
  YANKED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum EntitlementSource {
  PURCHASE
  PLAN
  GIFT
}

enum CampaignStatus {
  DRAFT
  RUNNING
  PAUSED
  FINISHED
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  /// Supabase Auth subject (JWT `sub`) — stable join key (email can change).
  authSubject      String?        @unique
  passwordHash     String
  name             String?
  role             Role           @default(USER)
  stripeCustomerId String?        @unique
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  devices       Device[]
  deviceGroups  DeviceGroup[]
  subscriptions Subscription[]
  entitlements  Entitlement[]
  payloads      Payload[]
  marketItems   MarketplaceItem[]
  campaigns     AdCampaign[]
  notifications Notification[]
  auditLogs     AuditLog[]
  featureRequests FeatureRequest[]
}

enum FeatureRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

/// An optional per-page feature a user enabled that needs manual admin approval
/// before it activates on the device (e.g. crypto price alerts).
model FeatureRequest {
  id        String               @id @default(cuid())
  userId    String
  user      User                 @relation(fields: [userId], references: [id])
  deviceId  String               // hardware id (ccp-xxxx)
  page      String               // e.g. "crypto"
  feature   String               // e.g. "alerts"
  detail    Json                 @default("{}") // requested config (alert rules…)
  status    FeatureRequestStatus @default(PENDING)
  decidedBy String?              // admin email
  decidedAt DateTime?
  createdAt DateTime             @default(now())

  @@index([status])
  @@index([deviceId])
}

model Device {
  id        String   @id @default(cuid())
  deviceId  String   @unique // hardware id, e.g. CCP000001 (provisioned) or ccp-a1b2c3d4e5f6
  name      String?
  model     String   @default("JC3248W535C")
  fwVersion String?
  /// wifi STA MAC, set at provision — used for encId = AES("<deviceId>-<MAC>")
  mac       String?
  /// short code (shown as QR/text) the buyer enters/scans to claim ownership
  claimCode String?
  /// bcrypt hash of the device MQTT/API token minted at claim/provision
  tokenHash String?
  ownerId   String?
  owner     User?    @relation(fields: [ownerId], references: [id])
  groupId   String?
  group     DeviceGroup? @relation(fields: [groupId], references: [id])

  activePayloadVersionId String?
  activePayloadVersion   PayloadVersion? @relation(fields: [activePayloadVersionId], references: [id])

  online     Boolean   @default(false)
  lastSeenAt DateTime?
  ip         String?
  rssi       Int?
  battMv     Int?
  fps        Float?
  sdFreeKb   BigInt?
  locked     Boolean   @default(false)

  /// per-device home-UI settings (device.json shape); device syncs at boot
  settings        Json @default("{}")
  settingsVersion Int  @default(0)

  claims      Claim[]
  impressions AdImpression[]
  configHead      DeviceConfigHead?
  pageSettings    DevicePageSettings[]
  configRevisions DeviceConfigRevision[]
  syncState       DeviceSyncState?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId])
  @@index([groupId])
}

/// One row per device: global config revision + device-wide system settings.
/// `compiledConfig` is an API-generated cache (never edit directly).
model DeviceConfigHead {
  deviceDbId     String   @id
  device         Device   @relation(fields: [deviceDbId], references: [id], onDelete: Cascade)
  revision       BigInt   @default(0)
  systemConfig   Json     @default("{}")
  compiledConfig Json     @default("{}")
  compiledSha256 String?
  updatedByUserId String?
  updatedSource  String   @default("system")
  updatedAt      DateTime @updatedAt
}

/// One row per page configured on a device. Canonical per-page values.
model DevicePageSettings {
  id             String   @id @default(cuid())
  deviceDbId     String
  device         Device   @relation(fields: [deviceDbId], references: [id], onDelete: Cascade)
  pageSlug       String
  schemaVersion  Int      @default(1)
  pageRevision   BigInt   @default(0)
  enabled        Boolean  @default(true)
  position       Int      @default(0)
  config         Json     @default("{}")
  updatedByUserId String?
  updatedSource  String   @default("system")
  updatedAt      DateTime @updatedAt

  @@unique([deviceDbId, pageSlug])
  @@index([deviceDbId, enabled, position])
}

/// Immutable audit history — one row per config/asset change.
model DeviceConfigRevision {
  id             String   @id @default(cuid())
  deviceDbId     String
  device         Device   @relation(fields: [deviceDbId], references: [id], onDelete: Cascade)
  globalRevision BigInt
  pageSlug       String?
  pageRevision   BigInt?
  changeType     String
  source         String   @default("system")
  actorUserId    String?
  beforeConfig   Json?
  afterConfig    Json?
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())

  @@index([deviceDbId, createdAt])
}

/// Desired vs applied revision for one device.
model DeviceSyncState {
  deviceDbId      String   @id
  device          Device   @relation(fields: [deviceDbId], references: [id], onDelete: Cascade)
  desiredRevision BigInt   @default(0)
  reportedRevision BigInt  @default(0)
  reportedSha256  String?
  status          String   @default("pending")
  lastNotifiedAt  DateTime?
  lastAppliedAt   DateTime?
  lastError       String?
  updatedAt       DateTime @updatedAt
}

model Claim {
  id              String      @id @default(cuid())
  code            String      @unique // short code shown on the device as QR
  deviceId        String
  device          Device      @relation(fields: [deviceId], references: [id])
  status          ClaimStatus @default(PENDING)
  claimedByUserId String?
  expiresAt       DateTime
  createdAt       DateTime    @default(now())

  @@index([deviceId])
}

/// Monotonic counters (e.g. the sequential CCP serial). Incremented in a txn.
model Counter {
  id    String @id // e.g. "device_ccp"
  value Int    @default(0)
}

model DeviceGroup {
  id      String   @id @default(cuid())
  name    String
  ownerId String
  owner   User     @relation(fields: [ownerId], references: [id])
  devices Device[]

  /// group-wide assignment; per-device assignment overrides it
  assignedPayloadVersionId String?
  assignedPayloadVersion   PayloadVersion? @relation(fields: [assignedPayloadVersionId], references: [id])

  createdAt DateTime @default(now())

  @@unique([ownerId, name])
}

model Plan {
  id            String  @id @default(cuid())
  name          String  @unique
  stripePriceId String? @unique
  features      Json    @default("{}")
  maxDevices    Int     @default(1)
  adFree        Boolean @default(false)
  priceCents    Int     @default(0)
  currency      String  @default("usd")

  subscriptions Subscription[]
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  user                 User               @relation(fields: [userId], references: [id])
  planId               String
  plan                 Plan               @relation(fields: [planId], references: [id])
  stripeSubscriptionId String?            @unique
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([userId])
}

model Payload {
  id        String      @id @default(cuid())
  packageId String      @unique // reverse-DNS, e.g. com.ccp.candles
  title     String
  type      PayloadType @default(LAYOUT)
  ownerId   String
  owner     User        @relation(fields: [ownerId], references: [id])
  versions  PayloadVersion[]
  marketItems MarketplaceItem[]
  createdAt DateTime    @default(now())
}

model PayloadVersion {
  id           String        @id @default(cuid())
  payloadId    String
  payload      Payload       @relation(fields: [payloadId], references: [id])
  version      String // semver
  minFwVersion String?
  bundleKey    String // object key in MinIO/S3
  bundleSha256 String
  sizeBytes    Int
  manifest     Json
  layout       Json?
  status       PayloadStatus @default(DRAFT)
  createdAt    DateTime      @default(now())

  devicesActive Device[]
  groupsAssigned DeviceGroup[]
  adCampaigns   AdCampaign[]

  @@unique([payloadId, version])
}

enum CatalogKind {
  PAGE
  FEATURE
}

model MarketplaceItem {
  id              String  @id @default(cuid())
  slug            String  @unique
  title           String
  description     String?
  kind            CatalogKind @default(PAGE) // PAGE = swipeable page, FEATURE = page add-on
  icon            String?
  authorId        String?
  author          User?   @relation(fields: [authorId], references: [id])
  payloadId       String? // null for feature add-ons / not-yet-bundled pages
  payloadRef      Payload? @relation(fields: [payloadId], references: [id])
  priceCents      Int     @default(0)
  currency        String  @default("usd")
  stripeProductId String?
  stripePriceId   String?
  published       Boolean @default(true)
  createdAt       DateTime @default(now())

  entitlements Entitlement[]
}

/// A page/feature unlocked on ONE specific device. Rights are per-CryptoClock,
/// not per-user: a user with two displays buys/unlocks separately for each.
/// userId = who paid/owns it; deviceId = the hardware id (ccp-xxxx) it applies to.
model Entitlement {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id])
  itemId    String
  item      MarketplaceItem   @relation(fields: [itemId], references: [id])
  deviceId  String            // hardware id the entitlement is bound to
  source    EntitlementSource @default(PURCHASE)
  createdAt DateTime          @default(now())

  @@unique([deviceId, itemId])
  @@index([userId])
  @@index([deviceId])
}

model AdCampaign {
  id           String         @id @default(cuid())
  advertiserId String
  advertiser   User           @relation(fields: [advertiserId], references: [id])
  name         String
  assetPayloadVersionId String?
  assetPayloadVersion   PayloadVersion? @relation(fields: [assetPayloadVersionId], references: [id])
  targeting    Json           @default("{}")
  cpmCents     Int            @default(0)
  budgetCents  Int            @default(0)
  spentCents   Int            @default(0)
  startsAt     DateTime?
  endsAt       DateTime?
  status       CampaignStatus @default(DRAFT)
  createdAt    DateTime       @default(now())

  impressions AdImpression[]
}

model AdImpression {
  id          String     @id @default(cuid())
  campaignId  String
  campaign    AdCampaign @relation(fields: [campaignId], references: [id])
  deviceId    String
  device      Device     @relation(fields: [deviceId], references: [id])
  shownAt     DateTime
  durationMs  Int        @default(0)
  billedCents Int        @default(0)

  @@index([campaignId, shownAt])
  @@index([deviceId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  kind      String
  payload   Json      @default("{}")
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actor       User?    @relation(fields: [actorUserId], references: [id])
  deviceId    String?
  action      String
  target      String?
  meta        Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([actorUserId])
  @@index([createdAt])
}
