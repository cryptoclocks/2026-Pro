# --- api ---
# Supabase pooler (Transaction mode, port 6543) — runtime path
# See https://supabase.com/dashboard/project/<REF>/settings/database for the
# connection string. Use the "Transaction" tab (port 6543) for runtime.
# If the password contains URL-special characters (@, /, #, %, etc.) you MUST
# percent-encode them. Example: my@pass → my%40pass
DATABASE_URL=postgresql://postgres.<REF>:<PASSWORD-PERCENT-ENCODED>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true

# Supabase direct (port 5432) — used by Prisma migrate deploy only
# Use the "Direct connection" tab on the same page.
DIRECT_URL=postgresql://postgres:<PASSWORD-PERCENT-ENCODED>@db.<REF>.supabase.co:5432/postgres

REDIS_URL=redis://localhost:6379

# MQTT broker (Node-RED / aedes). Local dev: aedes on node-red; prod: same host
MQTT_URL=mqtt://localhost:1883
MQTT_API_USERNAME=api-bridge
MQTT_API_PASSWORD=change-me

# Long random string used to sign ccp_dev_* JWTs for local testing
JWT_SECRET=dev-only-secret-change-in-production
PORT=4000

# --- object storage (MinIO local / S3 in prod) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=ccp_minio
S3_SECRET_KEY=ccp_minio_password
S3_BUCKET=ccp-payloads

# --- stripe (test keys — ใส่จริงเมื่อเปิดขาย) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- web ---
NEXT_PUBLIC_API_URL=http://localhost:4000

# URL ที่ "จอนาฬิกา" ใช้ดาวน์โหลด bundle.zip — ต้องเป็น IP LAN ของเครื่องนี้ ไม่ใช่ localhost
PUBLIC_API_URL=http://192.168.1.56:4000

# local-only dev login (ccpdev.* token signed with JWT_SECRET) — never set in production
CCP_DEV_AUTH=1

# --- auth (Supabase) ---
# Find at https://supabase.com/dashboard/project/<REF>/settings/api
SUPABASE_URL=https://<REF>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
# Comma-separated allowlist of admin emails (used by /auth/dev login to elevate role)
ADMIN_EMAILS=mycryptoclock@gmail.com
# Public web URL used in email links / OAuth redirects
PUBLIC_WEB_URL=http://localhost:3000
