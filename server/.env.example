# --- api ---
DATABASE_URL=postgresql://ccp:ccp_dev_password@localhost:5432/cryptoclock
# Prisma migrations use directUrl. Locally it's the same as DATABASE_URL; in
# production it's the Supabase direct (5432) string. See .env.prod.example.
DIRECT_URL=postgresql://ccp:ccp_dev_password@localhost:5432/cryptoclock
REDIS_URL=redis://localhost:6379
MQTT_URL=mqtt://localhost:1883
MQTT_API_USERNAME=api-bridge
MQTT_API_PASSWORD=change-me
JWT_SECRET=change-me-in-production
PORT=4000
PUBLIC_API_URL=https://api.example.com
PUBLIC_WEB_URL=https://admin.cashlessthailand.com
WEB_ORIGIN=https://admin.cashlessthailand.com,https://ccp-user.cashlessthailand.com
CCP_STAGED_ROLLOUT_OWNER_EMAIL=mycryptoclock@gmail.com

# --- object storage (MinIO locally, S3 in prod) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=ccp_minio
S3_SECRET_KEY=ccp_minio_password
S3_BUCKET=ccp-payloads

# --- stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- web ---
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-publishable-or-anon-key
NEXT_PUBLIC_MQTT_WS_URL=wss://mqtt-ccp.cashlessthailand.com/mqtt
