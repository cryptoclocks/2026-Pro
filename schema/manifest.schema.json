{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cryptoclock.pro/schema/manifest.schema.json",
  "title": "CryptoClock Pro package manifest",
  "description": "manifest.json at the root of every package zip. The device verifies every file hash before activating a package.",
  "type": "object",
  "required": ["manifest_version", "package_id", "version", "layout", "files"],
  "additionalProperties": false,
  "properties": {
    "manifest_version": { "type": "integer", "enum": [1] },
    "package_id": { "type": "string", "pattern": "^[a-z0-9]+(\\.[a-z0-9-]+)+$" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "min_fw_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "layout": { "type": "string", "description": "Path of the layout.json inside the zip", "default": "layout.json" },
    "wasm_entry": { "type": "string", "description": "Primary .wasm module path (optional)" },
    "total_size": { "type": "integer", "minimum": 0 },
    "signature": { "type": "string", "description": "Reserved for v1.1: ed25519 signature (base64) over the canonical manifest" },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256", "size"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string", "pattern": "^[^/\\\\][^\\\\]*$", "description": "Relative path, no leading slash, no backslashes, no .." },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "size": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
